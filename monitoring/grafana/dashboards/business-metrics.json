{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Tickets Created Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{service=\"ticketing-service\", route=\"/api/tickets\", method=\"POST\"}[1m]))",
          "legendFormat": "tickets/sec",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GPS Events Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{service=\"gps-service\", method=\"POST\"}[1m]))",
          "legendFormat": "gps events/sec",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Users (Login Rate)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{service=\"passenger-service\", route=~\".*login.*\"}[1m]))",
          "legendFormat": "logins/sec",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["urbanflow", "business"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "UrbanFlow Business Metrics",
  "uid": "urbanflow-business",
  "version": 1
}
