# Copy to mysql-secrets.yaml and replace values before applying.
# Never commit mysql-secrets.yaml to version control.
#
# kubectl create secret generic mysql-secrets \
#   --namespace urbanflow \
#   --from-literal=MYSQL_ROOT_PASSWORD='strong-root-password' \
#   --from-literal=MYSQL_USER='urbanflow' \
#   --from-literal=MYSQL_PASSWORD='strong-app-password' \
#   --dry-run=client -o yaml > secrets/mysql-secrets.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: mysql-secrets
  namespace: urbanflow
  labels:
    app.kubernetes.io/part-of: urbanflow
    app.kubernetes.io/component: database
type: Opaque
stringData:
  MYSQL_ROOT_PASSWORD: CHANGE_ME_STRONG_ROOT_PASSWORD
  MYSQL_USER: urbanflow
  MYSQL_PASSWORD: CHANGE_ME_STRONG_APP_PASSWORD
