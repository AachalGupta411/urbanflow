# Copy to app-secrets.yaml and replace values before applying.
# Never commit app-secrets.yaml to version control.
#
# kubectl create secret generic app-secrets \
#   --namespace urbanflow \
#   --from-literal=JWT_SECRET='your-256-bit-secret' \
#   --from-literal=AWS_ACCESS_KEY_ID='AKIA...' \
#   --from-literal=AWS_SECRET_ACCESS_KEY='your-aws-secret-key' \
#   --dry-run=client -o yaml > secrets/app-secrets.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: urbanflow
  labels:
    app.kubernetes.io/part-of: urbanflow
    app.kubernetes.io/component: secrets
type: Opaque
stringData:
  JWT_SECRET: CHANGE_ME_GENERATE_A_STRONG_256_BIT_SECRET
  AWS_ACCESS_KEY_ID: CHANGE_ME_AWS_ACCESS_KEY_ID
  AWS_SECRET_ACCESS_KEY: CHANGE_ME_AWS_SECRET_ACCESS_KEY
