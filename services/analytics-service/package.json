{
  "name": "@urbanflow/analytics-service",
  "version": "1.0.0",
  "private": true,
  "description": "UrbanFlow analytics aggregation and reporting microservice",
  "main": "src/index.js",
  "scripts": {
    "start": "NODE_PATH=./node_modules node src/index.js",
    "dev": "NODE_PATH=./node_modules node --watch src/index.js",
